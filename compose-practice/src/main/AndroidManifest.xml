<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ComposePractice">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep Link: study.example.com/profile/{userId} -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="study.example.com"
                    android:pathPrefix="/profile"
                    android:scheme="https" />
            </intent-filter>
        </activity>
        <!-- ShoppingApp: DeepLink 전용 Activity -->
        <activity
            android:name="com.murjune.pratice.compose.study.nav2.challenge.ShoppingActivity"
            android:exported="true">
            <!-- 커스텀 scheme: adb에서 바로 동작 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="study.example.com"
                    android:pathPrefix="/product"
                    android:scheme="app" />
            </intent-filter>
            <!-- https scheme: autoVerify=false로 앱 선택 다이얼로그 표시 -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="study.example.com"
                    android:pathPrefix="/product"
                    android:scheme="https" />
            </intent-filter>
        </activity>
    </application>

</manifest>
